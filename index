<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Cek RAW</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{background:#f4f6f9}
.card-box{border-radius:12px}
.badge-true{background:#198754}
.badge-false{background:#dc3545}
</style>

</head>
<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg bg-dark navbar-dark">
<div class="container">
<a class="navbar-brand fw-bold" href="/">Fatigue Tools</a>

<div>
<a href="/" class="btn btn-outline-light btn-sm">Bulk Check</a>
<a href="/report" class="btn btn-warning btn-sm">Reporting</a>
</div>
</div>
</nav>


<div class="container mt-4">

<h3 class="mb-3">🔎 Bulk Cek RAW</h3>

<!-- UPLOAD -->
<div class="card p-4 shadow-sm mb-4">

<form method="post" enctype="multipart/form-data">
<label class="mb-2">Upload File Event</label>
<input class="form-control mb-3" type="file" name="file" required>
<button class="btn btn-primary">Upload</button>
</form>

</div>

<!-- BULK -->
<div class="card p-4 shadow-sm">

<form method="post">

<textarea name="raw" id="rawInput" class="form-control" rows="6"
placeholder="Paste banyak raw di sini..."></textarea>

<div class="d-flex gap-2 mt-3">
<button class="btn btn-success w-100">Cek Semua</button>
<button type="button" class="btn btn-outline-secondary w-100"
onclick="document.getElementById('rawInput').value=''">Clear</button>
</div>

</form>

</div>


<!-- RESULT -->
{% if hasil %}

<div class="card mt-4 p-4 shadow-sm">

<div class="d-flex justify-content-between mb-3">
<h5>Hasil</h5>
<a href="/export" class="btn btn-success">Export Excel</a>
</div>

<div class="table-responsive">

<table class="table table-bordered table-striped table-hover">

<thead class="table-dark">
<tr>
<th>RAW</th>
<th>Unit</th>
<th>Alert</th>
<th>Kejadian</th>
<th>Gabungan</th>
<th>Status</th>
</tr>
</thead>

<tbody>

{% for r in hasil %}
<tr>
<td>{{ r[0] }}</td>
<td>{{ r[1] }}</td>
<td>{{ r[2] }}</td>
<td>{{ r[3] }}</td>
<td>{{ r[4] }}</td>

<td>
{% if r[5]|string|upper == "TRUE" %}
<span class="badge badge-true">TRUE</span>
{% else %}
<span class="badge badge-false">FALSE</span>
{% endif %}
</td>

</tr>
{% endfor %}

</tbody>

</table>

</div>

</div>

{% endif %}

</div>

<script>
document.getElementById("rawInput").focus();
</script>

</body>
</html>
