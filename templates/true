<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dashboard TRUE</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<script>
// 🔥 AUTO REFRESH 10 DETIK
setInterval(() => {
    location.reload();
}, 10000);
</script>

</head>

<body class="p-4">

<h3>🔥 Dashboard Intervensi TRUE</h3>

<!-- FILTER -->
<div class="d-flex gap-2 mb-3">

    <select id="site" class="form-select w-auto">
        <option value="brcg">BRCG</option>
        <option value="brcb">BRCB</option>
    </select>

    <input type="text" id="unit" class="form-control w-auto" placeholder="Filter Unit">

    <select id="jam" class="form-select w-auto">
        <option value="">Semua Jam</option>
        <option value="7">07</option>
        <option value="8">08</option>
        <option value="9">09</option>
        <option value="10">10</option>
        <option value="11">11</option>
    </select>

    <button class="btn btn-primary" onclick="applyFilter()">Filter</button>

</div>

<table class="table table-bordered text-center">
    <thead class="table-warning">
        <tr>
            <th>PID</th>
            <th>UNIT</th>
            <th>ALERT</th>
            <th>TIME</th>
            <th>VIDEO</th>
        </tr>
    </thead>

    <tbody>
    {% for r in data %}
    <tr>
        <!-- 🔥 CLICK PID -->
        <td>
            <a href="{{ r[5] }}" target="_blank" class="fw-bold">
                {{ r[0] }}
            </a>
        </td>

        <td>{{ r[1] }}</td>
        <td>{{ r[2] }}</td>
        <td>{{ r[3] }}</td>

        <td>
            <a href="{{ r[5] }}" target="_blank" class="btn btn-sm btn-success">
                ▶ View
            </a>
        </td>

    </tr>
    {% endfor %}
    </tbody>
</table>

<script>

// 🔥 APPLY FILTER
function applyFilter() {
    const site = document.getElementById("site").value;
    const unit = document.getElementById("unit").value;
    const jam = document.getElementById("jam").value;

    let url = `/true?site=${site}&unit=${unit}&jam=${jam}`;
    window.location.href = url;
}

</script>

</body>
</html>
